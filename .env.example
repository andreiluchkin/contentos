# Database
POSTGRES_PASSWORD=strong_password_here

# MinIO
MINIO_ROOT_USER=contentos_admin
MINIO_ROOT_PASSWORD=strong_minio_password

# API Auth — статический Bearer токен
API_SECRET_TOKEN=your_static_bearer_token_here

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Encryption key для токенов соцсетей
# Генерация: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Whisper
OPENAI_API_KEY=sk-...
WHISPER_MODE=api
WHISPER_LOCAL_MODEL=base

# OAuth — заполняется по мере подключения платформ
TELEGRAM_BOT_TOKEN=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
